datasource db {
  provider = "sqlite"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}



model User {
  id           String       @id @default(uuid())
  email        String       @unique
  password     String?      // Optional for Google login
  googleId     String?      @unique
  avatarUrl    String?
  name         String?
  role         String       @default("EDITOR")
  posts        Post[]
  movieReviews MovieReview[]
  bookReviews  BookReview[]
  savedMovies  SavedMovie[] @relation("UserSavedMovies")
  savedBooks   SavedBook[]  @relation("UserSavedBooks")
  notifications Notification[] @relation("UserNotifications")
  commentVotes CommentVote[]
  curatedLists CuratedList[]
  followers    Follows[] @relation("following")
  following    Follows[] @relation("follower")
  badges       UserBadge[]
  claimedBounties   Bounty[] @relation("ClaimedBounties")
  completedBounties Bounty[] @relation("CompletedBounties")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Post {
  id          String     @id @default(uuid())
  title       String
  slug        String     @unique
  content     String     // Stores HTML, Markdown, or JSON blocks
  status      String     @default("DRAFT")
  publishedAt DateTime?  // Set when actually published or scheduled
  authorId    String
  author      User       @relation(fields: [authorId], references: [id])
  tags        Tag[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Tag {
  id           String        @id @default(uuid())
  name         String        @unique
  posts        Post[]
  movieReviews MovieReview[]
  bookReviews  BookReview[]
}

model Webhook {
  id        String   @id @default(uuid())
  name      String
  url       String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model MovieReview {
  id          String       @id @default(uuid())
  title       String
  director    String
  releaseYear Int
  rating      Int          // 0 to 10 scale
  status      String       @default("PENDING") // PENDING, APPROVED, REJECTED
  theGood     String?
  theBad      String?
  watchDate   DateTime     @default(now())
  posterUrl   String?
  review      String
  authorId    String
  author      User         @relation(fields: [authorId], references: [id])
  comments    Comment[]
  savedBy     SavedMovie[]
  tags        Tag[]
  curatedListItems CuratedListItem[]
  bounty      Bounty?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model BookReview {
  id          String       @id @default(uuid())
  title       String
  author      String
  publishYear Int
  rating      Int          // 0 to 10 scale
  status      String       @default("PENDING") // PENDING, APPROVED, REJECTED
  theGood     String?
  theBad      String?
  readDate    DateTime     @default(now())
  coverUrl    String?
  review      String
  authorId    String
  userAuthor  User         @relation(fields: [authorId], references: [id])
  comments    Comment[]
  savedBy     SavedBook[]
  tags        Tag[]
  curatedListItems CuratedListItem[]
  bounty      Bounty?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Comment {
  id            String       @id @default(uuid())
  content       String
  authorName    String?      // Optional, for anonymous users
  movieReviewId String?
  bookReviewId  String?
  movieReview   MovieReview? @relation(fields: [movieReviewId], references: [id], onDelete: Cascade)
  bookReview    BookReview?  @relation(fields: [bookReviewId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
  parentId      String?
  parent        Comment?     @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies       Comment[]    @relation("CommentReplies")
  votes         CommentVote[]
}

model SavedMovie {
  id            String       @id @default(uuid())
  userId        String
  user          User         @relation("UserSavedMovies", fields: [userId], references: [id], onDelete: Cascade)
  movieReviewId String
  movieReview   MovieReview  @relation(fields: [movieReviewId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())

  @@unique([userId, movieReviewId])
}

model SavedBook {
  id           String       @id @default(uuid())
  userId       String
  user         User         @relation("UserSavedBooks", fields: [userId], references: [id], onDelete: Cascade)
  bookReviewId String
  bookReview   BookReview   @relation(fields: [bookReviewId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now())

  @@unique([userId, bookReviewId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "COMMENT", "REVIEW_APPROVED", etc.
  message   String
  link      String?  // Optional path e.g. "/review/movies/123"
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model CommentVote {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  value     Int      // 1 or -1
  createdAt DateTime @default(now())

  @@unique([userId, commentId])
}

model CuratedList {
  id          String   @id @default(uuid())
  title       String
  description String   // Overview of the list (Markdown supported)
  type        String   // "MOVIE" or "BOOK"
  status      String   @default("DRAFT") // "DRAFT" or "PUBLISHED"
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  coverUrl    String?
  items       CuratedListItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CuratedListItem {
  id            String       @id @default(uuid())
  listId        String
  list          CuratedList  @relation(fields: [listId], references: [id], onDelete: Cascade)
  movieReviewId String?
  movieReview   MovieReview? @relation(fields: [movieReviewId], references: [id], onDelete: Cascade)
  bookReviewId  String?
  bookReview    BookReview?  @relation(fields: [bookReviewId], references: [id], onDelete: Cascade)
  order         Int          // To determine ranking/sequence
  blurb         String       // Editorial reason for inclusion (Markdown supported)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([listId, movieReviewId])
  @@unique([listId, bookReviewId])
}

model Follows {
  followerId  String
  followingId String
  follower    User     @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@id([followerId, followingId])
}

model Badge {
  id          String   @id @default(uuid())
  name        String   @unique
  description String
  icon        String   // Emoji or string
  criteria    String   // Identifier like 'FIRST_REVIEW'
  users       UserBadge[]
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  awardedAt DateTime @default(now())

  @@unique([userId, badgeId])
}

model Bounty {
  id            String   @id @default(uuid())
  title         String   // The media title wanted
  type          String   // "MOVIE" or "BOOK"
  description   String   // Instructions/context from admin
  status        String   @default("OPEN") // OPEN, CLAIMED, COMPLETED
  rewardPoints  Int      @default(50)
  
  // Claiming
  claimedById   String?
  claimedBy     User?    @relation("ClaimedBounties", fields: [claimedById], references: [id], onDelete: SetNull)
  claimedAt     DateTime?
  
  // Completion
  completedById String?
  completedBy   User?    @relation("CompletedBounties", fields: [completedById], references: [id], onDelete: SetNull)
  completedAt   DateTime?
  
  // Link to the fulfilling review
  movieReviewId String?  @unique
  movieReview   MovieReview? @relation(fields: [movieReviewId], references: [id], onDelete: SetNull)
  
  bookReviewId  String?  @unique
  bookReview    BookReview? @relation(fields: [bookReviewId], references: [id], onDelete: SetNull)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
