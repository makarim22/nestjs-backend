datasource db {
  provider = "sqlite"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}



model User {
  id           String       @id @default(uuid())
  email        String       @unique
  password     String?      // Optional for Google login
  googleId     String?      @unique
  avatarUrl    String?
  name         String?
  role         String       @default("EDITOR")
  posts        Post[]
  movieReviews MovieReview[]
  bookReviews  BookReview[]
  savedMovies  SavedMovie[] @relation("UserSavedMovies")
  savedBooks   SavedBook[]  @relation("UserSavedBooks")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Post {
  id          String     @id @default(uuid())
  title       String
  slug        String     @unique
  content     String     // Stores HTML, Markdown, or JSON blocks
  status      String     @default("DRAFT")
  publishedAt DateTime?  // Set when actually published or scheduled
  authorId    String
  author      User       @relation(fields: [authorId], references: [id])
  tags        Tag[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Tag {
  id           String        @id @default(uuid())
  name         String        @unique
  posts        Post[]
  movieReviews MovieReview[]
  bookReviews  BookReview[]
}

model Webhook {
  id        String   @id @default(uuid())
  name      String
  url       String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model MovieReview {
  id          String       @id @default(uuid())
  title       String
  director    String
  releaseYear Int
  rating      Int          // 0 to 10 scale
  status      String       @default("PENDING") // PENDING, APPROVED, REJECTED
  theGood     String?
  theBad      String?
  watchDate   DateTime     @default(now())
  posterUrl   String?
  review      String
  authorId    String
  author      User         @relation(fields: [authorId], references: [id])
  comments    Comment[]
  savedBy     SavedMovie[]
  tags        Tag[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model BookReview {
  id          String       @id @default(uuid())
  title       String
  author      String
  publishYear Int
  rating      Int          // 0 to 10 scale
  status      String       @default("PENDING") // PENDING, APPROVED, REJECTED
  theGood     String?
  theBad      String?
  readDate    DateTime     @default(now())
  coverUrl    String?
  review      String
  authorId    String
  userAuthor  User         @relation(fields: [authorId], references: [id])
  comments    Comment[]
  savedBy     SavedBook[]
  tags        Tag[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Comment {
  id            String       @id @default(uuid())
  content       String
  authorName    String?      // Optional, for anonymous users
  movieReviewId String?
  bookReviewId  String?
  movieReview   MovieReview? @relation(fields: [movieReviewId], references: [id], onDelete: Cascade)
  bookReview    BookReview?  @relation(fields: [bookReviewId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
}

model SavedMovie {
  id            String       @id @default(uuid())
  userId        String
  user          User         @relation("UserSavedMovies", fields: [userId], references: [id], onDelete: Cascade)
  movieReviewId String
  movieReview   MovieReview  @relation(fields: [movieReviewId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())

  @@unique([userId, movieReviewId])
}

model SavedBook {
  id           String       @id @default(uuid())
  userId       String
  user         User         @relation("UserSavedBooks", fields: [userId], references: [id], onDelete: Cascade)
  bookReviewId String
  bookReview   BookReview   @relation(fields: [bookReviewId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now())

  @@unique([userId, bookReviewId])
}
